# ── Nintendo Switch Online ────────────────────────────────────────────────────
# Session token for your SECONDARY Nintendo account
# (the account that is friends with your main account).
# Run `npx nxapi nintendo auth` to start the login flow and obtain this token.
NSO_SESSION_TOKEN=

# Display name of your MAIN Switch account exactly as it appears to friends
# (Settings → Profile → Change Nickname on the Switch itself).
NSO_FRIEND_NAME=

# ── Steam ─────────────────────────────────────────────────────────────────────
# App ID for the Steam app whose Rich Presence slot you are using.
# Use 480 (Spacewar) while testing without a published app.
# Replace with your real Steamworks App ID for production.
STEAM_APP_ID=480
