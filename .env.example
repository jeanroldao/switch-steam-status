# ── Nintendo Switch Online ────────────────────────────────────────────────────

# User-agent string sent to nxapi's third-party services. Change the app name
# if you fork this project.
NXAPI_USER_AGENT=switch-steam-status/1.0.0

# Session token for your SECONDARY Nintendo account
# (the account that is friends with your main account).
# Run `npx nxapi nintendo auth` to start the login flow and obtain this token.
# Treat this like a password — it grants full access to that Nintendo account.
NSO_SESSION_TOKEN=

# Display name of your MAIN Switch account exactly as it appears to friends.
# Find it on your Switch: System Settings → Profile → Nickname (case-sensitive).
NSO_FRIEND_NAME=

# ── Steam ─────────────────────────────────────────────────────────────────────

# Full path to your Steam installation folder.
# Default on most Windows systems: C:\Program Files (x86)\Steam
STEAM_PATH=C:\Program Files (x86)\Steam

# Your Steam account ID — the lower 32 bits of your Steam64 ID.
# To find it: open https://steamid.io, look up your profile, copy the
# "steamID32" value (or subtract 76561197960265728 from your Steam64 ID).
STEAM_USER_ID=

# NOTE: do NOT set NXAPI_ZNCA_API_CLIENT_ID here. nxapi reads that env var
# directly and it overrides the internal ClientAssertionProvider auth, causing
# a 401 "Missing client authentication" error.
